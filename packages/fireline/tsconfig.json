{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": "../..",
    "paths": {
      "@fireline/client": ["packages/client/src/index.ts"],
      "@fireline/client/*": ["packages/client/src/*"],
      "@fireline/state": ["packages/state/src/index.ts"],
      "@fireline/state/*": ["packages/state/src/*"]
    },
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
