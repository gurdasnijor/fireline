{
  "name": "@fireline/cli",
  "version": "0.0.1",
  "description": "Fireline CLI — run declarative agent specs locally",
  "type": "module",
  "bin": {
    "fireline": "./bin/fireline.js",
    "fireline-agents": "./bin/fireline-agents.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @fireline/state build && pnpm --filter @fireline/client build && tsc",
    "lint": "pnpm --filter @fireline/state build && pnpm --filter @fireline/client build && tsc --noEmit",
    "test": "pnpm run build && node --test dist/cli.test.js dist/hosted-config.test.js dist/repl.test.js dist/repl-pane-conversation.test.js dist/repl-pane-events.test.js"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.2",
    "@durable-streams/client": "^0.2.3",
    "@fireline/client": "workspace:*",
    "@fireline/state": "workspace:*",
    "ink": "^7.0.0",
    "react": "^19.2.4",
    "tsx": "^4.20.6",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "@fireline/cli-darwin-arm64": "workspace:*",
    "@fireline/cli-darwin-x64": "workspace:*",
    "@fireline/cli-linux-arm64": "workspace:*",
    "@fireline/cli-linux-x64": "workspace:*",
    "@fireline/cli-win32-x64": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
