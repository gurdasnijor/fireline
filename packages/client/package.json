{
  "name": "@fireline/client",
  "version": "0.0.1",
  "private": true,
  "description": "Primitive-first TypeScript client for Fireline runtime host, state, and ACP surfaces",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "default": "./dist/host/index.js"
    },
    "./orchestration": {
      "types": "./dist/orchestration/index.d.ts",
      "default": "./dist/orchestration/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "default": "./dist/sandbox/index.js"
    },
    "./sandbox-local": {
      "types": "./dist/sandbox-local/index.d.ts",
      "default": "./dist/sandbox-local/index.js"
    },
    "./host-fireline": {
      "types": "./dist/host-fireline/index.d.ts",
      "default": "./dist/host-fireline/index.js"
    },
    "./host-claude": {
      "types": "./dist/host-claude/index.d.ts",
      "default": "./dist/host-claude/index.js"
    },
    "./host-hosted-api": {
      "types": "./dist/host-hosted-api/index.d.ts",
      "default": "./dist/host-hosted-api/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test:browser": "pnpm --dir ../.. --filter @fireline/browser-harness predev && vitest run --config vitest.browser.config.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.1",
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/state": "^0.2.3",
    "@fireline/state": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@tanstack/db": "^0.6.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/browser": "^2.1.9",
    "playwright": "^1.59.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
