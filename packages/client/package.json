{
  "name": "@fireline/client",
  "version": "0.0.1",
  "private": true,
  "description": "Primitive-first TypeScript client for Fireline runtime host, state, and ACP surfaces",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "default": "./dist/admin.js"
    },
    "./resources": {
      "types": "./dist/resources.d.ts",
      "default": "./dist/resources.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test:browser": "pnpm --dir ../.. --filter @fireline/browser-harness predev && vitest run --config vitest.browser.config.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.1",
    "@durable-streams/client": "^0.2.3",
    "@durable-streams/state": "^0.2.3",
    "@fireline/state": "workspace:*",
    "@tanstack/db": "^0.6.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/browser": "^2.1.9",
    "playwright": "^1.59.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
