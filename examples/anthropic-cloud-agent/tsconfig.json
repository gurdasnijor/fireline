{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@fireline/client": ["../../packages/client/src/index.ts"],
      "@fireline/client/*": ["../../packages/client/src/*"],
      "@fireline/state": ["../../packages/state/src/index.ts"]
    },
    "outDir": "./dist"
  },
  "include": ["./index.ts"]
}
