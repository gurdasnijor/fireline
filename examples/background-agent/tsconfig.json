{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "typeRoots": [
      "../../packages/client/node_modules/@types",
      "../../packages/browser-harness/node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "@agentclientprotocol/sdk": ["../../packages/client/node_modules/@agentclientprotocol/sdk"],
      "@fireline/client": ["../../packages/client/src/index.ts"],
      "@fireline/client/admin": ["../../packages/client/src/admin.ts"],
      "@fireline/client/events": ["../../packages/client/src/events.ts"],
      "@fireline/client/middleware": ["../../packages/client/src/middleware.ts"],
      "@fireline/client/resources": ["../../packages/client/src/resources.ts"],
      "@fireline/state": ["../../packages/state/src/index.ts"],
      "@tanstack/db": ["../../packages/client/node_modules/@tanstack/db"],
      "@tanstack/react-db": ["../../packages/browser-harness/node_modules/@tanstack/react-db"],
      "react": ["../../packages/browser-harness/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["../../packages/browser-harness/node_modules/@types/react/jsx-runtime.d.ts"],
      "use-acp": ["../shared/use-acp.d.ts"],
      "ws": ["../../packages/client/node_modules/@types/ws/index.d.ts"]
    }
  },
  "include": ["../shared/*.ts", "../shared/*.d.ts", "./**/*.ts", "./**/*.tsx"]
}
