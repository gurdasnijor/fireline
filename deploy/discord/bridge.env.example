# Discord bridge config for mono-thnc.6.3.*
# Copy to bridge.env (gitignored) and fill in tokens. NEVER commit the real .env.

DISCORD_BOT_TOKEN=<bot-token-from-discord-developer-portal>
DISCORD_GUILD_ID=<demo-server-id>
DISCORD_CHANNEL_ID=<demo-channel-id>

# Optional — bridge service config
BRIDGE_PORT=8787
BRIDGE_APPROVAL_WEBHOOK_PATH=/discord/interaction

# Wire to the same Fireline host that runs the agent
FIRELINE_URL=http://127.0.0.1:4440
FIRELINE_STATE_STREAM_URL=http://127.0.0.1:7474
