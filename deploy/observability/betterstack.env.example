# Betterstack OTLP export config for Fireline host
#
# Copy this file to betterstack.env (gitignored) and fill in the token.
# NEVER commit the token. The .env file belongs in the operator's local
# environment, not in the repo.
#
# Source: user-provisioned Betterstack source (platform=OpenTelemetry)
# ingesting at the host below. Region us-east-9.

# OTLP endpoint — direct ingestion URL for the Betterstack source.
OTEL_EXPORTER_OTLP_ENDPOINT=https://s2356898.us-east-9.betterstackdata.com

# OTLP headers — Bearer token auth. Replace <SOURCE_TOKEN> with the value
# obtained from the Betterstack source settings page. Keep in operator env
# only; never check in.
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <SOURCE_TOKEN>

# Service identity on the trace tree. Matches the Fireline default per
# docs/proposals/observability-integration.md §OTLP Export Config.
OTEL_SERVICE_NAME=fireline

# Optional: add resource attributes for per-environment tagging.
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=demo,service.instance.id=stage-1
