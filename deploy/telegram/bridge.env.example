# Telegram bridge config for mono-thnc.6.3.*
# Copy to bridge.env (gitignored) and fill in the token. NEVER commit the real .env.
#
# Bot created via @BotFather on Telegram (/newbot), ~2 minutes.

TELEGRAM_BOT_TOKEN=<paste-token-from-BotFather>

# Optional — if the demo targets a specific chat/group, paste its id here.
# Obtain via: message the bot from the target chat, then
#   curl -s "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/getUpdates" | jq '.result[].message.chat.id'
# TELEGRAM_CHAT_ID=

# Optional — whitelist allowed Telegram user IDs (comma-separated) so only the
# demo operator/audience can prompt the bot. Empty = open.
# TELEGRAM_ALLOWED_USER_IDS=

# Bridge service config
BRIDGE_PORT=8787
BRIDGE_CALLBACK_WEBHOOK_PATH=/telegram/callback

# Wire to the same Fireline host that runs the agent
FIRELINE_URL=http://127.0.0.1:4440

# IMPORTANT: set this to the exact `state:` URL printed by `fireline run`, not
# just the durable-streams base URL.
FIRELINE_STATE_STREAM_URL=http://127.0.0.1:7474/streams/state/default
